{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iantisdale.com/fundamentalstrainer/pbq-engine/schemas/ticket.schema.json",
  "title": "PBQ Engine Ticket Scenario",
  "description": "Schema for a stateful Ticket Engine v2 scenario used by the standalone PBQ Engine.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "engine",
    "title",
    "ticket",
    "initialState",
    "actions",
    "grading"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable unique scenario identifier."
    },
    "certification": {
      "type": "string",
      "minLength": 1
    },
    "exam": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "engine": {
      "const": "ticket"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "ticket": {
      "$ref": "#/$defs/ticketMetadata"
    },
    "initialState": {
      "$ref": "#/$defs/stateMap"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "grading": {
      "$ref": "#/$defs/grading"
    },
    "teachingNotes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "ticketMetadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["description"],
      "properties": {
        "number": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": ["Low", "Medium", "High", "Critical"]
        },
        "user": {
          "type": "string"
        },
        "department": {
          "type": "string"
        },
        "device": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stateMap": {
      "type": "object",
      "additionalProperties": {
        "type": ["boolean", "string", "number", "null"]
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "label"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "requires": {
          "$ref": "#/$defs/stateMap"
        },
        "sets": {
          "$ref": "#/$defs/stateMap"
        },
        "result": {
          "type": "string"
        },
        "good": {
          "type": "boolean"
        },
        "repeatable": {
          "type": "boolean"
        },
        "evidence": {
          "oneOf": [
            { "$ref": "#/$defs/evidence" },
            {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/evidence" }
            }
          ]
        },
        "penalty": {
          "$ref": "#/$defs/penalty"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "result": {
          "type": "string"
        }
      }
    },
    "penalty": {
      "type": "object",
      "additionalProperties": true,
      "required": ["points"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "unsafe",
            "insecure",
            "too-invasive",
            "not-relevant",
            "premature-escalation",
            "missed-verification",
            "missed-documentation",
            "penalty"
          ]
        },
        "points": {
          "type": "number",
          "minimum": 0
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "grading": {
      "type": "object",
      "additionalProperties": true,
      "required": ["requiredStates"],
      "properties": {
        "maxScore": {
          "type": "number",
          "minimum": 0,
          "default": 100
        },
        "passingScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 75
        },
        "pointsPerMissingState": {
          "type": "number",
          "minimum": 0
        },
        "summary": {
          "type": "string"
        },
        "requiredStates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/requiredState"
          }
        }
      }
    },
    "requiredState": {
      "type": "object",
      "additionalProperties": true,
      "required": ["key", "value"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": ["boolean", "string", "number", "null"]
        },
        "label": {
          "type": "string"
        }
      }
    }
  }
}
