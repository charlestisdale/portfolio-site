{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://charlestisdale.com/schemas/knowledge-object.schema.json",
  "title": "IT Learning Platform Knowledge Object",
  "description": "Canonical source record for one reusable learning concept. Assessments, flashcards, PBQs, search, analytics, and study guides should be generated from this object instead of hand-maintained duplicate question banks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "slug",
    "title",
    "type",
    "status",
    "domains",
    "certificationMappings",
    "learning",
    "assessmentSeeds",
    "relationships",
    "sources",
    "quality"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$",
      "description": "Stable unique id using domain.slug, such as commands.ipconfig or windows.task-manager."
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "default": []
    },
    "type": {
      "enum": [
        "concept",
        "command",
        "tool",
        "protocol",
        "service",
        "file-system",
        "operating-system",
        "procedure",
        "security-control",
        "hardware",
        "troubleshooting-pattern"
      ]
    },
    "status": {
      "enum": [
        "stub",
        "draft",
        "needs-review",
        "reviewed",
        "deprecated"
      ]
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "operating-systems",
          "software",
          "windows",
          "linux",
          "macos",
          "mobile",
          "networking",
          "security",
          "commands",
          "hardware",
          "cloud",
          "virtualization",
          "operational-procedures",
          "software-troubleshooting"
        ]
      }
    },
    "difficulty": {
      "enum": [
        "foundational",
        "intermediate",
        "advanced"
      ],
      "default": "foundational"
    },
    "importance": {
      "enum": [
        "low",
        "medium",
        "high",
        "exam-critical"
      ],
      "default": "medium"
    },
    "certificationMappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "certification",
          "objectives"
        ],
        "properties": {
          "certification": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "examCode": {
            "type": "string"
          },
          "objectives": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "name"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "weight": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "subtopics": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                }
              }
            }
          },
          "lessons": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "lessonId",
                "title"
              ],
              "properties": {
                "lessonId": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "order": {
                  "type": [
                    "integer",
                    "null"
                  ]
                }
              }
            },
            "default": []
          }
        }
      }
    },
    "learning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "explanation",
        "facts",
        "examples"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "explanation": {
          "type": "string",
          "default": ""
        },
        "facts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fact"
          },
          "default": []
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command"
          },
          "default": []
        },
        "examples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/example"
          },
          "default": []
        },
        "tables": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/table"
          },
          "default": []
        },
        "media": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/media"
          },
          "default": []
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "assessmentSeeds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "examTips",
        "commonMistakes",
        "scenarios",
        "pbqIdeas"
      ],
      "properties": {
        "examTips": { "type": "array", "items": { "$ref": "#/$defs/examTip" }, "default": [] },
        "commonMistakes": { "type": "array", "items": { "$ref": "#/$defs/commonMistake" }, "default": [] },
        "scenarios": { "type": "array", "items": { "$ref": "#/$defs/scenario" }, "default": [] },
        "pbqIdeas": { "type": "array", "items": { "$ref": "#/$defs/pbqIdea" }, "default": [] },
        "questionTargets": { "type": "array", "items": { "$ref": "#/$defs/questionTarget" }, "default": [] }
      }
    },
    "relationships": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prerequisites", "parents", "children", "related", "contrastsWith", "replacedBy"],
      "properties": {
        "prerequisites": { "type": "array", "items": { "type": "string" }, "default": [] },
        "parents": { "type": "array", "items": { "type": "string" }, "default": [] },
        "children": { "type": "array", "items": { "type": "string" }, "default": [] },
        "related": { "type": "array", "items": { "$ref": "#/$defs/relationship" }, "default": [] },
        "contrastsWith": { "type": "array", "items": { "$ref": "#/$defs/relationship" }, "default": [] },
        "replacedBy": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["references"],
      "properties": {
        "references": { "type": "array", "items": { "type": "object" }, "default": [] }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "importance", "tags"],
      "properties": {
        "text": { "type": "string" },
        "importance": { "enum": ["low", "medium", "high", "exam-critical"] },
        "tags": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": true
    },
    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "context", "tags"],
      "properties": {
        "text": { "type": "string" },
        "context": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    },
    "table": { "type": "object", "additionalProperties": true },
    "media": { "type": "object", "additionalProperties": true },
    "examTip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "difficulty", "tags"],
      "properties": {
        "text": { "type": "string" },
        "difficulty": { "enum": ["easy", "medium", "hard"] },
        "tags": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    },
    "commonMistake": {
      "type": "object",
      "additionalProperties": true
    },
    "scenario": {
      "type": "object",
      "additionalProperties": true
    },
    "pbqIdea": {
      "type": "object",
      "additionalProperties": true
    },
    "questionTarget": {
      "type": "object",
      "additionalProperties": true
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reason", "strength"],
      "properties": {
        "id": { "type": "string" },
        "reason": { "type": "string" },
        "strength": { "enum": ["weak", "medium", "strong"] }
      }
    }
  }
}
