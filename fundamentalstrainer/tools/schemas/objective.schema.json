{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://charlestisdale.com/schemas/objective.schema.json",
  "title": "Objective Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "certification", "objectives"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "certification": { "type": "string" },
    "source": { "type": "string" },
    "objectives": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "order"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "order": { "type": "integer" },
          "weight": { "type": ["number", "null"] },
          "children": { "type": "array", "items": { "$ref": "#/$defs/objectiveNode" }, "default": [] }
        }
      }
    }
  },
  "$defs": {
    "objectiveNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "order"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "integer" },
        "knowledgeIds": { "type": "array", "items": { "type": "string" }, "default": [] },
        "children": { "type": "array", "items": { "$ref": "#/$defs/objectiveNode" }, "default": [] }
      }
    }
  }
}
