{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://charlestisdale.com/schemas/assessment.schema.json",
  "title": "Assessment Item",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "type", "certification", "objectiveIds", "sourceKnowledgeIds", "difficulty", "status", "prompt", "explanation"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "id": { "type": "string" },
    "type": { "enum": ["multiple-choice", "true-false", "fill-blank", "matching", "ordering", "image", "scenario", "pbq", "flashcard"] },
    "certification": { "type": "string" },
    "objectiveIds": { "type": "array", "items": { "type": "string" } },
    "sourceKnowledgeIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "difficulty": { "enum": ["easy", "medium", "hard"] },
    "status": { "enum": ["generated", "needs-review", "reviewed", "retired"] },
    "prompt": { "type": "string" },
    "choices": { "type": "array", "items": { "type": "string" }, "default": [] },
    "answer": {},
    "explanation": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
    "mediaIds": { "type": "array", "items": { "type": "string" }, "default": [] },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceSeedIds": { "type": "array", "items": { "type": "string" } },
        "generatorVersion": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  }
}
