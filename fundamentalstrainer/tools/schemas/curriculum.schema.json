{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://charlestisdale.com/fundamentalstrainer/tools/schemas/curriculum.schema.json",
  "title": "Curriculum",
  "type": "object",
  "required": ["schemaVersion", "id", "title", "sections"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "enum": ["certification", "course", "custom-track"] },
    "certificationId": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "deprecated"] },
    "sections": {
      "type": "array",
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["id", "title", "order", "modules"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "objectiveIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "modules": {
          "type": "array",
          "items": { "$ref": "#/$defs/module" }
        }
      }
    },
    "module": {
      "type": "object",
      "required": ["id", "title", "order"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "estimatedMinutes": { "type": "number" },
        "outcomes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "knowledge": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*(\\.[a-z0-9][a-z0-9-]*)+$" }
        },
        "autoMap": { "$ref": "#/$defs/autoMap" },
        "notes": { "type": "string" }
      }
    },
    "autoMap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "idPrefixes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "titleIncludes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
