{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://charlestisdale.com/schemas/media.schema.json",
  "title": "Media Asset Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "type", "path", "title", "status"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "id": { "type": "string", "pattern": "^media\\.[a-z0-9.-]+$" },
    "type": { "enum": ["screenshot", "diagram", "icon", "simulated-output", "pbq-asset", "photo"] },
    "path": { "type": "string" },
    "title": { "type": "string" },
    "altText": { "type": "string" },
    "sourceKnowledgeIds": { "type": "array", "items": { "type": "string" }, "default": [] },
    "sourceLessonIds": { "type": "array", "items": { "type": "string" }, "default": [] },
    "status": { "enum": ["draft", "reviewed", "retired"] }
  }
}
