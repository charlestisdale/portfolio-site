{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://charlestisdale.com/schemas/relationship.schema.json",
  "title": "Knowledge Graph Relationship",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "sourceId", "targetId", "type", "strength", "direction", "status"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "id": { "type": "string", "pattern": "^rel\\.[a-z0-9.-]+\\.(requires|uses|configures|manages|troubleshoots|compares|contrasts_with|supersedes|belongs_to|parent_of|child_of|alternative_to|precedes|follows|appears_in)\\.[a-z0-9.-]+$" },
    "sourceId": { "type": "string", "minLength": 1 },
    "targetId": { "type": "string", "minLength": 1 },
    "type": { "enum": ["requires", "uses", "configures", "manages", "troubleshoots", "compares", "contrasts_with", "supersedes", "belongs_to", "parent_of", "child_of", "alternative_to", "precedes", "follows", "appears_in"] },
    "strength": { "enum": ["weak", "medium", "strong", "required"] },
    "direction": { "enum": ["outbound", "bidirectional"] },
    "status": { "enum": ["draft", "reviewed", "deprecated"] },
    "evidence": { "type": "array", "items": { "type": "string" }, "default": [] },
    "notes": { "type": "string", "default": "" },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" }
  }
}
