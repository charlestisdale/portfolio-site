{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://charlestisdale.com/schemas/lesson.schema.json",
  "title": "Lesson Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "certification", "lessons"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "certification": { "type": "string" },
    "lessons": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "order", "title", "status"],
        "properties": {
          "id": { "type": "string" },
          "order": { "type": "integer" },
          "title": { "type": "string" },
          "objectiveIds": { "type": "array", "items": { "type": "string" }, "default": [] },
          "rawTranscript": { "type": ["string", "null"] },
          "cleanedTranscript": { "type": ["string", "null"] },
          "importRecord": { "type": ["string", "null"] },
          "knowledgeIds": { "type": "array", "items": { "type": "string" }, "default": [] },
          "status": { "enum": ["not-started", "cleaned", "ingested", "reviewed"] }
        }
      }
    }
  }
}
