{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://charlestisdale.com/schemas/progress.schema.json",
  "title": "User Progress Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "scope", "entityId", "entityType", "mastery", "updatedAt"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "id": { "type": "string", "pattern": "^progress\\.[a-z0-9.-]+$" },
    "scope": { "enum": ["local", "user"] },
    "entityId": { "type": "string" },
    "entityType": { "enum": ["certification", "objective", "lesson", "knowledge", "assessment"] },
    "mastery": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence": { "enum": ["unknown", "low", "medium", "high"] },
    "attempts": { "type": "integer", "minimum": 0, "default": 0 },
    "correct": { "type": "integer", "minimum": 0, "default": 0 },
    "wrong": { "type": "integer", "minimum": 0, "default": 0 },
    "lastStudiedAt": { "type": ["string", "null"] },
    "updatedAt": { "type": "string" }
  }
}
