{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://it-learning-platform.local/schemas/ingestion-candidate.schema.json",
  "title": "Ingestion Candidate Set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "certificationId",
    "lessonId",
    "sourceTranscript",
    "status",
    "createdAt",
    "candidates"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^IMPORT-[A-Z0-9-]+$"
    },
    "certificationId": {
      "type": "string"
    },
    "lessonId": {
      "type": "string"
    },
    "sourceTranscript": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pending-review",
        "approved",
        "rejected",
        "merged"
      ]
    },
    "createdAt": {
      "type": "string"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateId",
        "title",
        "slug",
        "proposedKnowledgeId",
        "category",
        "confidence",
        "evidence",
        "reviewDecision"
      ],
      "properties": {
        "candidateId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "proposedKnowledgeId": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "summaryDraft": {
          "type": "string"
        },
        "factsDraft": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "examTipsDraft": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "line",
              "text"
            ],
            "properties": {
              "line": {
                "type": "integer"
              },
              "text": {
                "type": "string"
              }
            }
          }
        },
        "possibleDuplicates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "knowledgeId",
              "title",
              "reason"
            ],
            "properties": {
              "knowledgeId": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "score": {
                "type": "number"
              }
            }
          }
        },
        "suggestedRelationships": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "target",
              "type"
            ],
            "properties": {
              "target": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            }
          }
        },
        "reviewDecision": {
          "enum": [
            "undecided",
            "create-new",
            "merge-existing",
            "ignore"
          ]
        },
        "reviewNotes": {
          "type": "string"
        }
      }
    }
  }
}