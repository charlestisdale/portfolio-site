{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://charlestisdale.com/schemas/search-index.schema.json",
  "title": "Search Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "entries"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "generatedAt": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "entityType", "title", "text"],
        "properties": {
          "id": { "type": "string" },
          "entityType": { "enum": ["certification", "objective", "lesson", "knowledge", "assessment", "media"] },
          "title": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" }, "default": [] },
          "text": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
          "relatedIds": { "type": "array", "items": { "type": "string" }, "default": [] }
        }
      }
    }
  }
}
