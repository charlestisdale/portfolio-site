{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Transcript Import Record",
  "type": "object",
  "required": [
    "id",
    "certification",
    "lesson",
    "title",
    "sourceFile",
    "cleanedFile",
    "conceptsFound",
    "newKnowledgeObjects",
    "updatedKnowledgeObjects",
    "possibleDuplicates",
    "needsReview",
    "status"
  ],
  "properties": {
    "id": { "type": "string" },
    "certification": { "type": "string" },
    "lesson": { "type": "string" },
    "title": { "type": "string" },
    "sourceFile": { "type": "string" },
    "cleanedFile": { "type": "string" },
    "conceptsFound": { "type": "array", "items": { "type": "string" } },
    "newKnowledgeObjects": { "type": "array", "items": { "type": "string" } },
    "updatedKnowledgeObjects": { "type": "array", "items": { "type": "string" } },
    "possibleDuplicates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate", "matches", "reason"],
        "properties": {
          "candidate": { "type": "string" },
          "matches": { "type": "array", "items": { "type": "string" } },
          "reason": { "type": "string" }
        }
      }
    },
    "needsReview": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "reason"],
        "properties": {
          "item": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["not-started", "cleaned", "extracted", "merged", "reviewed"] }
  }
}
