  "learning": {
    "summary": "ipconfig is a Windows command-line tool used to view and troubleshoot IP configuration information.",
    "explanation": "Use ipconfig to inspect a Windows client network configuration before changing settings. It helps confirm whether the machine has a valid IP address, subnet mask, default gateway, DNS server, and DHCP lease information.",
    "facts": [
      {
        "text": "ipconfig shows IPv4 address, IPv6 address, subnet mask, and default gateway information.",
        "importance": "exam-critical",
        "tags": [
          "configuration"
        ]
      },
      {
        "text": "ipconfig /all shows detailed adapter information, including DNS servers and MAC address.",
        "importance": "exam-critical",
        "tags": [
          "dns",
          "mac-address"
        ]
      },
      {
        "text": "ipconfig /release releases a DHCP lease.",
        "importance": "high",
        "tags": [
          "dhcp"
        ]
      },
      {
        "text": "ipconfig /renew requests a new DHCP lease.",
        "importance": "high",
        "tags": [
          "dhcp"
        ]
      },
      {
        "text": "ipconfig /flushdns clears the local DNS resolver cache.",
        "importance": "high",
        "tags": [
          "dns"
        ]
      }
    ],
