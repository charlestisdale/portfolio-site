  "assessmentSeeds": {
    "examTips": [
      {
        "text": "For checking a client's assigned IP address, default gateway, or DNS server, think ipconfig.",
        "difficulty": "easy",
        "tags": [
          "command-selection"
        ]
      }
    ],
    "commonMistakes": [
      {
        "text": "Using ipconfig to test connectivity. ipconfig shows configuration; ping tests reachability.",
        "difficulty": "medium",
        "tags": [
          "command-selection"
        ]
      },
      {
        "text": "Forgetting that /flushdns clears cache but does not fix an incorrect DNS server setting.",
