  "definitions": [
    {
      "term": "Operating System",
      "definition": "Software that manages hardware resources and provides the platform for applications."
    },
    {
      "term": "Linux Distribution",
      "definition": "A packaged implementation of Linux tailored for a specific purpose or audience."
    },
    {
      "term": "End of Life",
      "definition": "The point at which a vendor no longer supports an operating system."
    }
